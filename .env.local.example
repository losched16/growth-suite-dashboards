# Growth Suite Dashboards — Environment Variables
# Copy to .env.local and fill in real values.

# Same Supabase project as importer and family graph (additive migration).
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@<host>:5432/postgres

# Kept for parity; not strictly required.
ANTHROPIC_API_KEY=sk-ant-...

# Operator password (single user). Same value as importer + family graph.
ADMIN_PASSWORD=change-me-strong-password

# CRITICAL: must be byte-identical to the importer's ENCRYPTION_KEY for PIT decryption.
ENCRYPTION_KEY=base64-encoded-32-bytes

# CRITICAL: must be byte-identical to the family graph's INTERNAL_API_TOKEN.
INTERNAL_API_TOKEN=base64-encoded-32-bytes

# 32 random bytes, base64. Operator session cookie HMAC.
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
SESSION_SECRET=base64-encoded-32-bytes

# 32 random bytes, base64. School-admin session JWT signing key.
SCHOOL_SESSION_SECRET=base64-encoded-32-bytes

# 32 random bytes, base64. Shared with GHL Custom Menu Link configuration —
# GHL signs the menu link's `?token=<JWT>` param using this secret; we verify
# with the same value.
GHL_LOGIN_SECRET=base64-encoded-32-bytes

# Base URL of the deployed family graph service. Service-to-service calls.
FAMILY_GRAPH_URL=https://growth-suite-family-graph.vercel.app

NEXT_PUBLIC_APP_NAME=Growth Suite Dashboards
